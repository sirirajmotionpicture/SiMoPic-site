---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayoutFull.astro';
import Prose from '../components/Prose.astro';

const pageTitle = "Movie Night - Siriraj Motion Picture Club";

//description and hero image
import Content from '../content/movienight.md';
import contentImg from '../assets/banners/movienight.jpg';

// import only published movienight collection entries 
import { getCollection } from 'astro:content';
const publishedMovieNight = await getCollection('movienight', ({ data }) => {
  return data.draft !== true;
});

// sort by date
const sortedMovieNight = publishedMovieNight.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

//const d = today
const d = new Date();
