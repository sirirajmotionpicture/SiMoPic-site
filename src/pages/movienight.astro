    <div class="w-full h-[calc(var(--banner-height-sm)*2/3)] md:h-[calc(var(--banner-height)*2/3)] relative flex m-auto">
        <div class="flex m-auto italic font-bold text-center text-4xl">
            COMING SOON
        </div>
    </div>
    

